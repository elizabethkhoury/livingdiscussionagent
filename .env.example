APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reddit_agent
REDIS_URL=redis://localhost:6379/0
TEMPORAL_TARGET=localhost:7233
TEMPORAL_TASK_QUEUE=reddit-agent
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

REDDIT_USER_AGENT=PromptHuntAgent/2.0
OPENAI_API_KEY=
OPENAI_BASE_URL=
KERNEL_API_KEY=
KERNEL_PROFILE_ID=
KERNEL_PROFILE_NAME=reddit-agent
KERNEL_BROWSER_TIMEOUT_SECONDS=120
KERNEL_HEADLESS=true
BROWSER_AGENT_MODEL=gpt-5.4-mini
BROWSER_AGENT_BASE_URL=
BROWSER_AGENT_API_KEY=
REDDIT_DISCOVERY_THREAD_LIMIT=10
REDDIT_DISCOVERY_COMMENT_SNIPPET_LIMIT=3

LLM_MODE=openai
GENERATION_MODEL=gpt-5.4
EVALUATOR_MODEL=gpt-5.4-mini

DASHBOARD_API_ORIGIN=http://localhost:8000
